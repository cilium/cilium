hive/start
db/show health

k8s/add policy.yaml
k8s/resources
k8s/list cilium.io.v2.ciliumnetworkpolicies default

-- policy.yaml --
apiVersion: cilium.io/v2
kind: CiliumNetworkPolicy
metadata:
  name: "policy"
  namespace: "default"
specs:
- endpointSelector: {}
  egress:
    - toEndpoints:
      - matchLabels: {}
    - toEndpoints:
      - matchLabels:
          "k8s:io.kubernetes.pod.namespace": kube-system
          "k8s:k8s-app": kube-dns
      toPorts:
      - ports:
        - port: "53"
          protocol: "UDP"
        rules:
          dns:
          - matchPattern: "*"
    - toFQDNs:
      - matchPattern: "*"
      - matchPattern: "ifconfig.co"
    - toCIDR:
      - "1.1.1.1/32"
