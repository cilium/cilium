hive/start

identity/allocate reserved:kube-apiserver
env --from-stdout apiserver_id

identity/allocate reserved:world
env --from-stdout world_id

env pod_labels=k8s:io.kubernetes.pod.namespace=default,k8s:app=test
identity/allocate ${pod_labels}
env --from-stdout pod_id
endpoint/create ${pod_id} ${pod_labels}

policy/import allow-all-egress.yaml
policy/import deny-kube-apiserver.yaml
endpoint/regen-all 3
endpoint/wait-for-policy-revision 3

policy/lookup-flow ${pod_id} ${apiserver_id} tcp 443
stdout egress=denied

policy/lookup-flow ${pod_id} ${world_id} tcp 80
stdout egress=allowed

-- allow-all-egress.yaml --
apiVersion: cilium.io/v2
kind: CiliumNetworkPolicy
metadata:
  name: to-entities-all
  namespace: default
spec:
  endpointSelector: {}
  egress:
  - toEntities:
    - all

-- deny-kube-apiserver.yaml --
apiVersion: cilium.io/v2
kind: CiliumNetworkPolicy
metadata:
  name: to-entities-kube-apiserver-deny
  namespace: default
spec:
  endpointSelector: {}
  egressDeny:
  - toEntities:
    - kube-apiserver
