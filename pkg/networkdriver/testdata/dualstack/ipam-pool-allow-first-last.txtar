-- node.expected.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  labels:
    kubernetes.io/hostname: test-local-node
  name: test-local-node
spec:
  alibaba-cloud: {}
  azure: {}
  encryption: {}
  eni: {}
  health: {}
  ingress: {}
  ipam:
    pools: {}
    resourcepools:
      allocated:
      - allowFirstIP: true
        allowLastIP: true
        cidrs:
        - 10.10.0.0/30
        - fd00:200:1::/126
        pool: test-ip-pool
      requested:
      - needed:
          ipv4-addrs: 4
          ipv6-addrs: 4
        pool: test-ip-pool
status:
  alibaba-cloud: {}
  azure: {}
  eni: {}
  ipam:
    operator-status: {}
