# Start hive
hive start

# Add objects
k8s/add ippool.yaml node.yaml claim.yaml
driver/ipam/restore-finished

# Prepare claim
# Just like in a real cluster, this is retried until successful. An initial failure
# is not an error: as an example, when referencing a CiliumResourceIPPool, the address
# allocation fails until the operator assigns a CIDR to the node.
* driver/prepare-resource-claims default/test-pod-test-4d5bl

# Check allocated addresses are from the pool. Four dual-stack allocations
# exhaust the /30 and /126 CIDRs, so this only succeeds if the first and last
# IPs are allocatable.
* driver/check-claim-addresses default/test-pod-test-4d5bl test-device-1 test-ip-pool
* driver/check-claim-addresses default/test-pod-test-4d5bl test-device-2 test-ip-pool
* driver/check-claim-addresses default/test-pod-test-4d5bl test-device-3 test-ip-pool
* driver/check-claim-addresses default/test-pod-test-4d5bl test-device-4 test-ip-pool

# Check ResourceClaim status redacting transition time and randomized IP addresses.
k8s/get resource.k8s.io.v1.resourceclaims default/test-pod-test-4d5bl -o claim.actual.yaml
sed 'lastTransitionTime: ".*"' 'lastTransitionTime: "<timestamp>"' claim.actual.yaml
sed 'ipv4Addr: .*' 'ipv4Addr: <redacted>' claim.actual.yaml
sed 'ipv6Addr: .*' 'ipv6Addr: <redacted>' claim.actual.yaml
sed '- 10\.10\.0\..*/32' '- <redacted>' claim.actual.yaml
sed '- fd00:200:1::.*/128' '- <redacted>' claim.actual.yaml
cmp claim.actual.yaml claim.expected.yaml

# Check CiliumNode resource pools after allocation.
k8s/get cilium.io.v2.ciliumnodes test-local-node -o node.actual.yaml
* cmp node.actual.yaml node.expected.yaml

# Unprepare claim.
driver/unprepare-resource-claims default/test-pod-test-4d5bl

# Check CiliumNode resource pools after release.
k8s/get cilium.io.v2.ciliumnodes test-local-node -o node-released.actual.yaml
* cmp node-released.actual.yaml node-released.expected.yaml

# Stop hive
hive stop

-- ippool.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumResourceIPPool
metadata:
  name: test-ip-pool
spec:
  allowFirstIP: true
  allowLastIP: true
  ipv4:
    cidrs:
    - 10.10.0.0/30
    maskSize: 30
  ipv6:
    cidrs:
    - fd00:200:1::/126
    maskSize: 126

-- node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: test-local-node
  labels:
    kubernetes.io/hostname: test-local-node
spec: {}

-- claim.yaml --
apiVersion: resource.k8s.io/v1
kind: ResourceClaim
metadata:
  name: test-pod-test-4d5bl
  namespace: default
  uid: ba3c7922-9a56-44eb-a96f-84ee8b74dd23
spec: {}
status:
  allocation:
    devices:
      config:
      - source: FromClaim
        requests:
        - test-request-1
        opaque:
          driver: test.cilium.k8s.io
          parameters:
            ip-pool: test-ip-pool
      - source: FromClaim
        requests:
        - test-request-2
        opaque:
          driver: test.cilium.k8s.io
          parameters:
            ip-pool: test-ip-pool
      - source: FromClaim
        requests:
        - test-request-3
        opaque:
          driver: test.cilium.k8s.io
          parameters:
            ip-pool: test-ip-pool
      - source: FromClaim
        requests:
        - test-request-4
        opaque:
          driver: test.cilium.k8s.io
          parameters:
            ip-pool: test-ip-pool
      results:
      - device: test-device-1
        driver: test.cilium.k8s.io
        pool: test-device-1-pool
        request: test-request-1
      - device: test-device-2
        driver: test.cilium.k8s.io
        pool: test-device-2-pool
        request: test-request-2
      - device: test-device-3
        driver: test.cilium.k8s.io
        pool: test-device-3-pool
        request: test-request-3
      - device: test-device-4
        driver: test.cilium.k8s.io
        pool: test-device-4-pool
        request: test-request-4
  reservedFor:
  - resource: pods
    name: test-pod
    uid: bec9dd67-13f9-4d4b-a3c1-76fc3e485e68

