-- service.yaml --
apiVersion: v1
kind: Service
metadata:
  creationTimestamp: "2023-02-02T01:21:10Z"
  name: eps-weight-svc
  namespace: test
  resourceVersion: "663"
  uid: be7e85d4-6d27-400b-aff2-bd7284837fc9
spec:
  clusterIP: 10.96.116.33
  clusterIPs:
  - 10.96.116.33
  internalTrafficPolicy: Cluster
  ipFamilies:
  - IPv4
  ipFamilyPolicy: SingleStack
  ports:
  - port: 8081
    protocol: TCP
    targetPort: 8081
  selector:
    app: eps-weight-server
  sessionAffinity: None
  type: ClusterIP
status:
  loadBalancer: {}

