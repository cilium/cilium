{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "Cilium BGP — BMP Monitoring",
  "uid": "cilium-bmp",
  "tags": ["cilium", "bgp", "bmp"],
  "timezone": "browser",
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Loki data source",
        "type": "datasource",
        "query": "loki",
        "refresh": 1,
        "hide": 0,
        "current": {}
      },
      {
        "name": "router",
        "label": "BMP router",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "query": { "label": "bmp_router", "stream": "{job=\"bmp\"}", "type": 1 },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "BMP messages by type (rate) — router: $router",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (bmp_msg_type) (count_over_time({job=\"bmp\", bmp_router=~\"$router\"}[1m]))",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "BMP messages by router (node)",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (bmp_router) (count_over_time({job=\"bmp\", bmp_router=~\"$router\"}[1m]))",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Route-monitor updates (last 30m)",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"bmp\", bmp_router=~\"$router\", bmp_msg_type=\"route_monitor\"}[$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Peer up/down events (last 30m)",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"bmp\", bmp_router=~\"$router\", bmp_msg_type=~\"peer_up|peer_down\"}[$__range]))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Active BMP routers",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "purple", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "none", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "count(sum by (bmp_router) (count_over_time({job=\"bmp\", bmp_router=~\"$router\"}[$__range])))",
          "queryType": "instant"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Advertised / received prefixes (route_monitor)",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "options": { "showHeader": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"bmp\", bmp_router=~\"$router\", bmp_msg_type=\"route_monitor\"} | json | line_format \"router={{.bmp_router}}\\t{{.ip_prefix}}\\tnh={{.bgp_nexthop}}\\tAS {{.as_path}}\\tloc={{.is_loc}} post={{.is_post}}\"",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Raw BMP event stream",
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "options": { "showTime": true, "wrapLogMessage": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{job=\"bmp\", bmp_router=~\"$router\"}",
          "queryType": "range"
        }
      ]
    }
  ]
}
