# Test that catch-all cannot override another catch-all
hive start

# Create a CiliumNode
k8s/add node1.yaml

# Create first catch-all ClusterConfig
k8s/add config-catch-all-1.yaml

# Wait for reconciliation
sleep 1s

# Verify NodeConfig was created from first catch-all
k8s/get cilium.io.v2alpha1.ciliumnetworkdrivernodeconfigs node1 -o actual-node1.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' actual-node1.yaml
* cmp expected-node1-catchall1.yaml actual-node1.yaml

# Create second catch-all ClusterConfig (should cause conflict)
k8s/add config-catch-all-2.yaml

# Wait for reconciliation
sleep 1s

# Verify NodeConfig was NOT updated (still has catchall-1)
k8s/get cilium.io.v2alpha1.ciliumnetworkdrivernodeconfigs node1 -o actual-node1-after.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' actual-node1-after.yaml
* cmp expected-node1-catchall1.yaml actual-node1-after.yaml

# Verify second catch-all config has Conflict condition
k8s/get cilium.io.v2alpha1.ciliumnetworkdriverclusterconfigs config-catch-all-2 -o actual-catchall2-status.yaml
* grep 'type: Conflict' actual-catchall2-status.yaml
* grep 'status: "True"' actual-catchall2-status.yaml

# Verify first catch-all config has no conflict
k8s/get cilium.io.v2alpha1.ciliumnetworkdriverclusterconfigs config-catch-all-1 -o actual-catchall1-status.yaml
! grep 'type: Conflict' actual-catchall1-status.yaml

hive stop

#####

-- node1.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: node1
  labels:
    kubernetes.io/hostname: node1
spec:
  addresses:
  - ip: 10.0.0.1
    type: InternalIP

-- config-catch-all-1.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverClusterConfig
metadata:
  name: config-catch-all-1
spec:
  spec:
    driverName: driver1

-- config-catch-all-2.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverClusterConfig
metadata:
  name: config-catch-all-2
spec:
  spec:
    driverName: driver2

-- expected-node1-catchall1.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverNodeConfig
metadata:
  annotations:
    cilium.io/had-selector: "false"
    cilium.io/source-cluster-config: config-catch-all-1
  name: node1
  resourceVersion: "<nr>"
spec:
  driverName: driver1
status:
  managedBy: operator
