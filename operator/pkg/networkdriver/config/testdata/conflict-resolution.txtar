# Test that conflict status is cleared when conflicting config is removed
hive start

# Create a CiliumNode
k8s/add node1.yaml

# Create first ClusterConfig with selector
k8s/add config1.yaml

# Wait for reconciliation
sleep 1s

# Verify NodeConfig was created with correct annotations
k8s/get cilium.io.v2alpha1.ciliumnetworkdrivernodeconfigs node1 -o actual-node1.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' actual-node1.yaml
* cmp expected-node1-from-config1.yaml actual-node1.yaml

# Verify config1 has no conflict status
k8s/get cilium.io.v2alpha1.ciliumnetworkdriverclusterconfigs config1 -o actual-config1-status.yaml
! grep 'type: Conflict' actual-config1-status.yaml

# Create second ClusterConfig with selector (should cause conflict)
k8s/add config2.yaml

# Wait for reconciliation
sleep 1s

# Verify config2 has Conflict condition in status
k8s/get cilium.io.v2alpha1.ciliumnetworkdriverclusterconfigs config2 -o actual-config2-status.yaml
* grep 'type: Conflict' actual-config2-status.yaml
* grep 'status: "True"' actual-config2-status.yaml

# Delete the first config (should allow config2 to take over)
k8s/delete config1.yaml

# Wait for reconciliation
sleep 1s

# Verify NodeConfig is now managed by config2
k8s/get cilium.io.v2alpha1.ciliumnetworkdrivernodeconfigs node1 -o actual-node1-after.yaml
sed 'resourceVersion: ".*"' 'resourceVersion: "<nr>"' actual-node1-after.yaml
* cmp expected-node1-from-config2.yaml actual-node1-after.yaml

# Verify config2's conflict status is cleared
k8s/get cilium.io.v2alpha1.ciliumnetworkdriverclusterconfigs config2 -o actual-config2-resolved.yaml
! grep 'status: "True"' actual-config2-resolved.yaml

hive stop

#####

-- node1.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  name: node1
  labels:
    kubernetes.io/hostname: node1
    role: worker
spec:
  addresses:
  - ip: 10.0.0.1
    type: InternalIP
-- config1.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverClusterConfig
metadata:
  name: config1
spec:
  nodeSelector:
    matchLabels:
      role: worker
  spec:
    driverName: driver1
-- config2.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverClusterConfig
metadata:
  name: config2
spec:
  nodeSelector:
    matchLabels:
      role: worker
  spec:
    driverName: driver2
-- expected-node1-from-config1.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverNodeConfig
metadata:
  annotations:
    cilium.io/had-selector: "true"
    cilium.io/source-cluster-config: config1
  name: node1
  resourceVersion: "<nr>"
spec:
  driverName: driver1
status:
  managedBy: operator
-- expected-node1-from-config2.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverNodeConfig
metadata:
  annotations:
    cilium.io/had-selector: "true"
    cilium.io/source-cluster-config: config2
  name: node1
  resourceVersion: "<nr>"
spec:
  driverName: driver2
status:
  managedBy: operator
