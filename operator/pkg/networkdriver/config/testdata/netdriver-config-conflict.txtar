hive start

# Add kind-control-plane and kind-worker nodes

k8s/add kind-control-plane-node.yaml
k8s/add kind-worker-node.yaml

# Add a cluster configuration matching kind-worker

k8s/add driver-cluster-config-1.yaml

* k8s/get cilium.io.v2alpha1.ciliumnetworkdrivernodeconfigs kind-worker -o kind-worker-config-actual.yaml
* cmp kind-worker-config-expected.yaml kind-worker-config-actual.yaml

# Add another cluster configuration conflicting with the previous one on kind-worker

k8s/add driver-cluster-config-2.yaml

# driver-cluster-config-2 should be marked as conflicting

db/cmp k8s-netdriver-cluster-config cluster-config.table

# kind-worker node config should not be changed

k8s/get cilium.io.v2alpha1.ciliumnetworkdrivernodeconfigs kind-worker -o kind-worker-config-actual.yaml
cmp kind-worker-config-expected.yaml kind-worker-config-actual.yaml

hive stop

# ----

-- kind-control-plane-node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  labels:
    kubernetes.io/hostname: kind-control-plane
  name: kind-control-plane
spec:

-- kind-worker-node.yaml --
apiVersion: cilium.io/v2
kind: CiliumNode
metadata:
  labels:
    kubernetes.io/hostname: kind-worker
  name: kind-worker
spec:

-- driver-cluster-config-1.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverClusterConfig
metadata:
  name: driver-cluster-config
spec:
  nodeSelector:
    matchLabels:
        kubernetes.io/hostname: kind-worker
  spec:
    draRegistrationRetryInterval: 1
    draRegistrationTimeout: 600
    publishInterval: 10
    driverName: "dummy.cilium.k8s.io"
    pools:
      - name: "dummy-pool"
        filter:
          deviceManagers:
            - "dummy"
    deviceManagerConfigs:
      dummy:
        enabled: true

-- driver-cluster-config-2.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverClusterConfig
metadata:
  name: driver-cluster-config-2
spec:
  nodeSelector:
    matchLabels:
        kubernetes.io/hostname: kind-worker
  spec:
    draRegistrationRetryInterval: 2
    draRegistrationTimeout: 500
    publishInterval: 15
    driverName: "dummy.cilium.k8s.io"
    pools:
      - name: "dummy-pool-2"
        filter:
          deviceManagers:
            - "dummy"
    deviceManagerConfigs:
      dummy:
        enabled: true

-- kind-worker-config-expected.yaml --
apiVersion: cilium.io/v2alpha1
kind: CiliumNetworkDriverNodeConfig
metadata:
  name: kind-worker
spec:
  deviceManagerConfigs:
    dummy:
      enabled: true
  draRegistrationRetryInterval: 1
  draRegistrationTimeout: 600
  driverName: dummy.cilium.k8s.io
  pools:
  - filter:
      deviceManagers:
      - dummy
    name: dummy-pool
  publishInterval: 10
-- cluster-config.table --
Name                     NodeConfig                                                                                                                                                                                                                                        NodeSelector                        Conditions                                       Age
driver-cluster-config    {"draRegistrationRetryInterval":1,"draRegistrationTimeout":600,"publishInterval":10,"driverName":"dummy.cilium.k8s.io","pools":[{"name":"dummy-pool","filter":{"deviceManagers":["dummy"]}}],"deviceManagerConfigs":{"dummy":{"enabled":true}}}   kubernetes.io/hostname=kind-worker                                                   0s
driver-cluster-config-2  {"draRegistrationRetryInterval":2,"draRegistrationTimeout":500,"publishInterval":15,"driverName":"dummy.cilium.k8s.io","pools":[{"name":"dummy-pool-2","filter":{"deviceManagers":["dummy"]}}],"deviceManagerConfigs":{"dummy":{"enabled":true}}} kubernetes.io/hostname=kind-worker  cilium.io/ConflictingClusterConfiguration:True   0s